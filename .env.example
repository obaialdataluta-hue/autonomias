# ═══════════════════════════════════════════════════════════════════
# ObAIAL Pipeline — exemplo de configuração local (.env)
# ───────────────────────────────────────────────────────────────────
# Copie para .env e preencha. O arquivo .env É IGNORADO PELO GIT.
#
# Em produção (AWS Lambda) NÃO se usa este arquivo: as credenciais
# vêm do AWS Secrets Manager e as variáveis abaixo são definidas no
# template SAM. Este .env serve apenas para rodar localmente.
# ═══════════════════════════════════════════════════════════════════

# ── Claude API ──────────────────────────────────────────────────────
# Para desenvolvimento local, coloque a chave aqui.
# Em produção ela vem do Secrets Manager (ver ANTHROPIC_SECRET_ID).
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional — override do modelo:
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── AWS / Secrets Manager ───────────────────────────────────────────
# Região e IDs dos segredos. Os defaults do código já apontam para
# estes valores; descomente apenas se precisar sobrescrever.
# OBAIAL_AWS_REGION=sa-east-1
# GMAIL_TOKEN_SECRET_ID=gmail/obaial/token
# SHEETS_SA_SECRET_ID=gcp/sheets_service_account
# ANTHROPIC_SECRET_ID=anthropic/obaial/api_key

# ── Google Sheets ───────────────────────────────────────────────────
# OBAIAL_SPREADSHEET_ID=1Bhhkozi3mduOqwz3VuYjeosLZ3GxrvGV0mAoHyYpwqw
# OBAIAL_SHEET_NAME=Obial

# ── Gravação / Backfill mensal em chunks ────────────────────────────
# Lotes pequenos de gravação (resiliente a timeout):
# OBAIAL_FLUSH_EVERY=5
# Abas auxiliares (criadas automaticamente se não existirem):
# OBAIAL_ESTADO_TAB=ESTADO
# OBAIAL_DESTINATARIOS_TAB=DESTINATARIOS
# Orçamento de tempo do chunk local e reserva para flush/cursor (ms):
# OBAIAL_CHUNK_BUDGET_MS=480000
# OBAIAL_CHUNK_RESERVE_MS=120000

# ── Digest por e-mail + few-shot ────────────────────────────────────
# OBAIAL_DIGEST_RESUMO_LEN=240
# OBAIAL_DIGEST_N_POSITIVOS=5
# OBAIAL_DIGEST_N_NEGATIVOS=3
# OBAIAL_FEWSHOT_MAX=12

# ── Outros ──────────────────────────────────────────────────────────
# OBAIAL_TIMEZONE=America/Sao_Paulo
# OBAIAL_GEOCODE_CACHE=geocode_cache.json
# LOG_LEVEL=INFO
